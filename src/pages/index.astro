---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import backgroundImage from '../assets/images/background.jpg';
import logoImage from '../assets/images/logo_zdrowestopy.png';
---

<BaseLayout
  title="Zdrowe Stopy - Specjalistyczny Gabinet Podologiczny"
  description="Specjalistyczny Gabinet Podologiczny. Profesjonalne zabiegi podologiczne, nowoczesny sprzęt i najwyższe standardy higieny. Zadbaj o swoje stopy."
  bodyClass="flex flex-col"
>
  <main class="flex-1 relative min-h-screen">
    <section class="relative">

      <!-- ═══════ DESKTOP HERO (visible > 880px) ═══════ -->
      <div class="hero-desktop relative min-h-screen flex items-center pt-24 pb-12 w-full">
        <div class="absolute inset-0 z-0">
          <Image 
            src={backgroundImage} 
            alt="" 
            fetchpriority="high" 
            loading="eager" 
            class="w-full h-full object-cover object-[95%_center]"
            widths={[240, 540, 720, backgroundImage.width]}
            sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 720px, ${backgroundImage.width}px`}
            quality="mid"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-background via-background/40 to-transparent">
          </div>
        </div>
        <div class="relative z-10 max-w-[1800px] mx-auto px-8 w-full">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            <!-- Left Text Column -->
            <div class="lg:col-span-6 xl:col-span-5 relative">
              <div
                class="bg-white/30 backdrop-blur-2xl border border-white/20 rounded-[2.5rem] shadow-2xl shadow-emerald-900/10 p-10 md:p-12 py-12 md:py-16 flex flex-col gap-y-8">
                <div>
                  <div class="flex items-center justify-between mb-8">
                    <div
                      class="status-badge flex items-center gap-3 bg-white/40 backdrop-blur-md p-3 px-6 rounded-2xl border border-white/50 w-fit shadow-sm">
                      <div
                        class="status-indicator w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]">
                      </div>
                      <div class="flex flex-col">
                        <span
                          class="status-text font-bold text-slate-900 text-sm leading-none uppercase tracking-wider">Otwarte</span>
                        <span
                          class="status-time text-[10px] text-slate-500 font-bold uppercase tracking-wider mt-1">do
                          17:00</span>
                      </div>
                    </div>
                    <Image 
                      src={logoImage} 
                      alt="Zdrowe Stopy Logo"
                      class="h-28 md:h-32 w-auto page-enter zoom-in"
                      loading="eager"
                      fetchpriority="high"
                    />
                  </div>
                  <h1 class="font-serif text-3xl md:text-5xl lg:text-6xl text-primary mb-0 leading-[1.1] tracking-tight page-enter fade-right"
                    style="font-family: 'Playfair Display', serif;">Twoje stopy w rękach
                    specjalisty.
                  </h1>
                </div>
                <p class="font-sans text-base md:text-lg text-secondary max-w-lg leading-relaxed">
                  Zdrowe stopy to nie tylko estetyka, to Twój komfort każdego dnia. Pomagam pozbyć się
                  bólu i przywracam pewność siebie, dbając o każdy szczegół w spokojnym, domowym
                  klimacie.</p>
                <div class="flex flex-wrap items-center gap-6">
                  <button onclick="openProassist()"
                    class="btn-reserve bg-primary text-on-primary px-8 py-4 rounded-xl font-label-md text-base cursor-pointer">
                    Zarezerwuj wizytę
                  </button>
                  <a href="/oferta"
                    class="hero-btn-secondary border border-white/40 bg-white/20 backdrop-blur-2xl px-8 py-4 rounded-xl font-label-md text-base text-primary hover:bg-white/40 flex items-center justify-center">
                    Poznaj usługi
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══════ MOBILE HERO (visible ≤ 880px) ═══════ -->
      <div class="hero-mobile pt-32 pb-12 px-6 flex-col items-center gap-7 text-center relative overflow-hidden">
        <div class="absolute inset-0 z-0">
          <Image 
            src={backgroundImage} 
            alt="" 
            fetchpriority="high" 
            loading="eager" 
            class="w-full h-full object-cover object-center"
            widths={[240, 540, 720]}
            sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, 720px`}
            quality="mid"
          />
        </div>
        <div class="absolute inset-0 z-1"
          style="background: linear-gradient(to bottom, rgba(240,250,245,0.60) 0%, rgba(240,250,245,0.40) 60%, rgba(209,235,220,0.65) 100%);">
        </div>
        <!-- content wrapper above overlay -->
        <div class="relative z-10 flex flex-col items-center gap-7 w-full flex-1">

          <!-- 1. Duże logo (krzyż) -->
          <Image 
            src={logoImage} 
            alt="Zdrowe Stopy Logo"
            class="h-36 w-auto drop-shadow-md page-enter zoom-in"
            loading="eager"
            fetchpriority="high"
          />

          <!-- 2. Status Otwarcia -->
          <div
            class="status-badge flex items-center gap-3 bg-white p-3 px-4 rounded-2xl border border-emerald-100 shadow-sm w-fit mx-auto page-enter zoom-in">
            <div
              class="status-indicator w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]">
            </div>
            <div class="flex flex-col text-left">
              <span
                class="status-text font-bold text-slate-900 text-sm leading-none uppercase tracking-wider">Otwarte</span>
              <span
                class="status-time text-[10px] text-slate-500 font-bold uppercase tracking-wider mt-1">do
                17:00</span>
            </div>
          </div>

          <!-- 3. Główny napis -->
          <div class="flex flex-col gap-4">
            <h1 class="font-serif text-4xl text-primary leading-[1.1] tracking-tight page-enter fade-right"
              style="font-family: 'Playfair Display', serif;">Twoje stopy<br>w rękach specjalisty.</h1>
          </div>

          <!-- 4. Dwa przyciski -->
          <div class="flex flex-col gap-3 w-full mt-auto">
            <button onclick="openProassist()"
              class="btn-reserve bg-primary text-on-primary px-8 py-4 rounded-xl font-label-md text-base w-full cursor-pointer">
              Zarezerwuj wizytę
            </button>
            <a href="/oferta"
              class="hero-btn-secondary border border-emerald-900/10 bg-white/30 backdrop-blur-2xl px-8 py-4 rounded-xl font-label-md text-base text-primary hover:bg-white/40 w-full flex items-center justify-center">
              Poznaj usługi
            </a>
          </div>

        </div><!-- end relative z-10 wrapper -->
      </div>

    </section>
  </main>

  <script src="../scripts/status.js"></script>
</BaseLayout>
