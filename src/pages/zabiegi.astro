            </div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700 text-base">Wycena indywidualna</span>
