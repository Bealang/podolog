          <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm transition-all duration-300 flex flex-col justify-between group cursor-default">
            <div class="mb-6">
              <h3 class="font-headline-md text-lg text-slate-800 mb-3 transition-colors">Kontrola klamry</h3>
