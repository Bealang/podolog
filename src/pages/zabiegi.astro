---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import logoImage from '../assets/images/logo_zdrowestopy.png';
import podologiaStopyImage from '../assets/images/podologia_stopy.jpg';

// Optymalizacja zdjęć zabiegów
const treatmentImages = import.meta.glob('../assets/images/zabiegi_zdjecia/*.{png,jpg,jpeg,webp}');
const optimizedImages = {};

for (const path in treatmentImages) {
  const fileName = path.split('/').pop();
  const image = (await treatmentImages[path]());
  const optimized = await getImage({ 
    src: image.default, 
    width: 800, 
    format: 'webp',
    quality: 80 
  });
  optimizedImages[fileName] = optimized.src;
}
---

<BaseLayout
  title="Podologia Stóp - Cennik - Zdrowe Stopy"
  description="Sprawdź cennik zabiegów podologicznych: pielęgnacja stóp, terapia paznokci, korekcja wrastających paznokci, usuwanie brodawek."
>
  <main class="pt-32 pb-section-gap px-4 md:px-8 bg-slate-50/50 min-h-screen">
    <!-- Header -->
    <section class="max-w-7xl mx-auto mb-20 grid grid-cols-1 lg:grid-cols-3 items-center gap-12 text-center">
      <div class="hidden lg:flex items-center justify-end">
        <div class="w-64 h-64 flex items-center justify-center">
          <Image src={logoImage} alt="Logo Zdrowe Stopy" class="w-48 h-auto opacity-90" />
        </div>
      </div>
      <div class="flex flex-col items-center justify-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-headline-xl text-primary mb-4 tracking-tight">PODOLOGIA STÓP</h1>
        <p class="font-body-lg text-slate-500 max-w-[280px] mx-auto leading-relaxed">Zapoznaj się z ofertą mojej profesjonalnej pielęgnacji i terapii stóp</p>
      </div>
      <div class="hidden lg:flex items-center justify-start">
        <div class="w-64 h-64 overflow-hidden rounded-[2.5rem] shadow-xl border-4 border-white">
          <Image src={podologiaStopyImage} alt="Podologia Stóp" class="w-full h-full object-cover" />
        </div>
      </div>
    </section>

    <!-- Pricing Container -->
    <section class="max-w-5xl mx-auto space-y-16">

      <!-- ZABIEGI PODSTAWOWE I PROFILAKTYKA -->
      <div>
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px bg-slate-300 flex-1"></div>
          <h2 class="font-headline-md text-xl text-emerald-800 uppercase tracking-wide">Zabiegi podstawowe i profilaktyka</h2>
          <div class="h-px bg-slate-300 flex-1"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm transition-all duration-300 flex flex-col justify-between group cursor-default">
            <div class="mb-6">
              <h3 class="font-headline-md text-lg text-slate-800 mb-3 transition-colors">Podstawowy zabieg podologiczny</h3>
              <p class="font-body-md text-slate-500 text-sm leading-relaxed">Usunięcie zrogowaceń i skórek, skrócenie oraz wyfrezowanie paznokci.</p>
            </div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700">od 180 PLN</span>
            </div>
          </div>
          <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm transition-all duration-300 flex flex-col justify-between group cursor-default">
            <div class="mb-6">
              <h3 class="font-headline-md text-lg text-slate-800 mb-3 transition-colors">Badanie stopy cukrzycowej</h3>
              <p class="font-body-md text-slate-500 text-sm leading-relaxed">Diagnostyka czucia oraz profesjonalna pielęgnacja stóp u diabetyków.</p>
            </div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700">od 150 PLN</span>
            </div>
          </div>
          <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm transition-all duration-300 flex flex-col justify-between group cursor-default">
            <div class="mb-6">
