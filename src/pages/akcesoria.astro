---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import logoImage from '../assets/images/logo_zdrowestopy.png';
---

<BaseLayout
  title="Akcesoria i Kosmetyki do Stóp - Zdrowe Stopy Myślenice"
  description="Profesjonalne kosmetyki do pielęgnacji stóp i dłoni oraz akcesoria podologiczne dostępne w gabinecie Zdrowe Stopy w Myślenicach. Zadbaj o domową pielęgnację."
>
  <main class="pt-32 pb-section-gap px-4 md:px-8 bg-slate-50/50 min-h-screen">
    <!-- Header -->
    <section class="max-w-7xl mx-auto mb-20 grid grid-cols-1 lg:grid-cols-3 items-center gap-12 text-center">
      <div class="hidden lg:flex items-center justify-end">
        <div class="w-64 h-64 flex items-center justify-center">
          <Image src={logoImage} alt="Logo Zdrowe Stopy" class="w-48 h-auto opacity-90" />
        </div>
      </div>
      <div class="flex flex-col items-center justify-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-headline-xl text-primary mb-4 tracking-tight uppercase">Akcesoria i kosmetyki</h1>
        <p class="font-body-lg text-slate-500 max-w-[280px] mx-auto leading-relaxed">Specjalistyczne produkty do pielęgnacji i wsparcia Twoich stóp</p>
      </div>
      <div class="hidden lg:flex items-center justify-start">
        <div class="w-64 h-64 overflow-hidden rounded-[2.5rem] shadow-xl border-4 border-white">
          <img 
            src="/images/akecesoriaikosmetyki.jpg" 
            alt="Akcesoria i kosmetyki podologiczne" 
            class="w-full h-full object-cover" 
          />
        </div>
      </div>
    </section>

    <!-- Content Container -->
    <section class="max-w-6xl mx-auto px-4">
      <div class="bg-white p-10 md:p-16 rounded-[3rem] border border-emerald-100/50 shadow-sm relative overflow-hidden">
        <!-- Decorative element -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-50/50 rounded-bl-full -mr-16 -mt-16"></div>
        
        <div class="relative z-10 space-y-8">
          <p class="font-body-lg text-slate-700 leading-relaxed text-lg md:text-xl">
            W moim gabinecie podologicznym oferuję możliwość zakupu starannie wyselekcjonowanych kosmetyków oraz preparatów przeznaczonych do profesjonalnej pielęgnacji skóry stóp dłoni i paznokci. W asortymencie znajdują się produkty wspomagające codzienną pielęgnację, regenerację oraz profilaktykę problemów podologicznych.
          </p>
          
          <p class="font-body-lg text-slate-700 leading-relaxed text-lg md:text-xl">
            Dodatkowo prowadzę sprzedaż wkładek ortopedycznych, ortez i odciążeń dopasowanych do potrzeb i komfortu pacjenta. Oferta obejmuje również medyczne klapki ortopedyczne wspierające prawidłowe ustawianie stóp i poprawę komfortu chodzenia.
          </p>
        </div>

        <div class="mt-12 flex items-center gap-4 text-emerald-700">
          <span class="material-symbols-outlined">info</span>
          <p class="text-sm font-medium italic">Produkty dostępne do zakupu stacjonarnie w gabinecie.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
