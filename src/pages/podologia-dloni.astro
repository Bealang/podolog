---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import logoImage from '../assets/images/logo_zdrowestopy.png';
import podologiaDlonieImage from '../assets/images/podologia_dlonie.jpg';

// Optymalizacja zdjęć zabiegów
const treatmentImages = import.meta.glob('../assets/images/zabiegi_zdjecia/*.{png,jpg,jpeg,webp}');
const optimizedImages = {};

for (const path in treatmentImages) {
  const fileName = path.split('/').pop();
  const image = (await treatmentImages[path]());
  const optimized = await getImage({ 
    src: image.default, 
    width: 800, 
    format: 'webp',
    quality: 80 
  });
  optimizedImages[fileName] = optimized.src;
}
---

<BaseLayout
  title="Podologia Dłoni i Manicure Medyczny - Zdrowe Stopy Myślenice"
  description="Specjalistyczna pielęgnacja dłoni i terapia paznokci u rąk. Profesjonalny manicure medyczny w gabinecie Zdrowe Stopy Myślenice."
>
  <main class="pt-32 pb-section-gap px-4 md:px-8 bg-slate-50/50 min-h-screen">
    <!-- Header -->
    <section class="max-w-7xl mx-auto mb-20 grid grid-cols-1 lg:grid-cols-3 items-center gap-12 text-center">
      <div class="hidden lg:flex items-center justify-end">
        <div class="w-64 h-64 flex items-center justify-center">
          <Image src={logoImage} alt="Logo Zdrowe Stopy" class="w-48 h-auto opacity-90" />
        </div>
      </div>
      <div class="flex flex-col items-center justify-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-headline-xl text-primary mb-4 tracking-tight uppercase">Podologia Dłoni<br><span class="text-2xl sm:text-3xl opacity-70">MYŚLENICE</span></h1>
        <p class="font-body-lg text-slate-500 max-w-[280px] mx-auto leading-relaxed">Zapoznaj się z ofertą mojej profesjonalnej pielęgnacji i terapii dłoni</p>
      </div>
      <div class="hidden lg:flex items-center justify-start">
        <div class="w-64 h-64 overflow-hidden rounded-[2.5rem] shadow-xl border-4 border-white">
          <Image 
            src={podologiaDlonieImage} 
            alt="Podologia Dłoni" 
            width={600}
            height={600}
            quality="mid"
            class="w-full h-full object-cover" 
          />
        </div>
      </div>
    </section>

    <!-- Pricing Container -->
    <section class="max-w-5xl mx-auto space-y-16">
      <div>
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px bg-slate-300 flex-1"></div>
          <h2 class="font-headline-md text-xl text-emerald-800 uppercase tracking-wide">Zabiegi i terapie</h2>
          <div class="h-px bg-slate-300 flex-1"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between group cursor-default">
            <div class="mb-4">
              <h3 class="font-headline-md text-lg text-slate-800 transition-colors">Zakażenie bakteryjne</h3>
              <p class="font-body-md text-slate-500 text-sm leading-relaxed mt-2">Zobacz efekty profesjonalnej terapii.</p>
            </div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700">120 PLN</span>
            </div>
          </div>
          <div data-no-modal class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between group cursor-default">
            <div class="mb-4"><h3 class="font-headline-md text-lg text-slate-800 transition-colors">Onycholiza</h3></div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700">120 PLN</span>
            </div>
          </div>
          <div data-no-modal class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between group cursor-default">
            <div class="mb-4"><h3 class="font-headline-md text-lg text-slate-800 transition-colors">Przebarwienia i krwiaki podpaznokciowe</h3></div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700">120 PLN</span>
            </div>
          </div>
          <div data-no-modal class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between group cursor-default">
            <div class="mb-4"><h3 class="font-headline-md text-lg text-slate-800 transition-colors">Zakażenia grzybicze</h3></div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700">120 PLN</span>
            </div>
          </div>
          <div data-no-modal class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between group cursor-default">
            <div class="mb-4"><h3 class="font-headline-md text-lg text-slate-800 transition-colors">Brodawki wirusowe</h3></div>
            <div class="flex justify-between items-end border-t border-slate-100 pt-4 mt-auto">
              <span class="font-label-sm text-slate-400 uppercase tracking-widest text-xs">Cena</span>
              <span class="font-headline-md text-emerald-700">120 PLN</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script define:vars={{ optimizedImages }}>
    window.TREATMENT_IMAGES = optimizedImages;
  </script>
  <script src="../scripts/treatments-modal.js"></script>
</BaseLayout>
